+    glpriv->gl.module = module_need(&glpriv->gl, type, name, true);
+    if (glpriv->gl.module == NULL)
+    {
+        vlc_gl_Release(master);
+        vlc_object_release(&glpriv->gl);
+        return NULL;
+    }
+    atomic_init(&glpriv->ref_count, 1);
+    return &glpriv->gl;
+}
