     :segment(p_seg)
@@ -456,6 +597,7 @@ void matroska_segment_c::LoadTags( KaxTags *tags )
         }
     }
 
+    Open3DMkvApplyTrackSubtitleTags(*this);
     msg_Dbg( &sys.demuxer, "loading tags done." );
